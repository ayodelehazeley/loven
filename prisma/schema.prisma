// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique // e.g., "Pastries", "Savory Pies"
  slug      String    @unique
  items     Item[]
  createdAt DateTime  @default(now())
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  basePrice   Float
  imageUrl    String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  // For items sold in multiples (e.g., Meat Pies Dozen vs Individual)
  variants    Variant[] 
  
  isAvailable Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Variant {
  id        String  @id @default(cuid())
  name      String  // e.g., "Single", "Dozen", "Half-Dozen"
  price     Float
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerPhone String
  deliveryAddr  String?
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  itemName  String
  quantity  Int
  price     Float
}

enum OrderStatus {
  PENDING
  PREPARING
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}